    "variable": "#dfdfe0",
    "function.go": "#8cb6ff",
    "variable.go": "#dfdfe0",
    "parameter.go": "#dfdfe0",
    "property.go": "#78a9ff",
    "namespace.go": "#33b1ff",
    "function": "#8cb6ff",
