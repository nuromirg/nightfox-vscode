  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "name": "Comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6e6f70"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "name": "String",
      "settings": {
        "foreground": "#25be6a"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "name": "Regexp",
      "settings": {
        "foreground": "#2dc7c4"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.numeric"
      ],
      "name": "Number",
      "settings": {
        "foreground": "#3ddbd9"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character.escape"
      ],
      "name": "Constant",
      "settings": {
        "foreground": "#5ae0df"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "name": "Variable",
      "settings": {
        "foreground": "#dfdfe0"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "name": "Variable Property",
      "settings": {
        "foreground": "#78a9ff"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "name": "Keyword",
      "settings": {
        "foreground": "#be95ff"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "name": "Operator",
      "settings": {
        "foreground": "#b6b8bb"
      }
    },
    {
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "name": "Conditional",
      "settings": {
        "foreground": "#c8a5ff"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "name": "Function",
      "settings": {
        "foreground": "#8cb6ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "name": "Type",
      "settings": {
        "foreground": "#08bdba"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "name": "Class",
      "settings": {
        "foreground": "#08bdba"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "name": "Builtin Type",
      "settings": {
        "foreground": "#52bdff"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "name": "Builtin Variable",
      "settings": {
        "foreground": "#ee5396"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "name": "Builtin Constant",
      "settings": {
        "foreground": "#5ae0df"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "name": "Identifier",
      "settings": {
        "foreground": "#33b1ff"
      }
    },
    {
      "scope": [
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "name": "Preprocessor",
      "settings": {
        "foreground": "#ff91c1"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "name": "Tag",
      "settings": {
        "foreground": "#be95ff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "name": "Tag Attribute",
      "settings": {
        "foreground": "#78a9ff"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "name": "Brackets",
      "settings": {
        "foreground": "#b6b8bb"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "name": "Deprecated",
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#7b7c7e"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "name": "Invalid",
      "settings": {
        "foreground": "#ee5396"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "name": "Markdown Heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#8cb6ff"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "name": "Markdown Bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#be95ff"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "name": "Markdown Italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#be95ff"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "name": "Markdown Code",
      "settings": {
        "foreground": "#25be6a"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "name": "Markdown Link",
      "settings": {
        "foreground": "#33b1ff"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "name": "Markdown Quote",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6e6f70"
      }
    }
  ],
  "name": "carbonfox",
