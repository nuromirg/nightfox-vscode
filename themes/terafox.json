  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "name": "Comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6d7f8b"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "name": "String",
      "settings": {
        "foreground": "#7aa4a1"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "name": "Regexp",
      "settings": {
        "foreground": "#fdb292"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.numeric"
      ],
      "name": "Number",
      "settings": {
        "foreground": "#ff8349"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character.escape"
      ],
      "name": "Constant",
      "settings": {
        "foreground": "#ff9664"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "name": "Variable",
      "settings": {
        "foreground": "#ebebeb"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "name": "Variable Property",
      "settings": {
        "foreground": "#5a93aa"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "name": "Keyword",
      "settings": {
        "foreground": "#ad5c7c"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "name": "Operator",
      "settings": {
        "foreground": "#cbd9d8"
      }
    },
    {
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "name": "Conditional",
      "settings": {
        "foreground": "#b97490"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "name": "Function",
      "settings": {
        "foreground": "#73a3b7"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "name": "Type",
      "settings": {
        "foreground": "#fda47f"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "name": "Class",
      "settings": {
        "foreground": "#fda47f"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "name": "Builtin Type",
      "settings": {
        "foreground": "#afd4de"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "name": "Builtin Variable",
      "settings": {
        "foreground": "#e85c51"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "name": "Builtin Constant",
      "settings": {
        "foreground": "#ff9664"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "name": "Identifier",
      "settings": {
        "foreground": "#a1cdd8"
      }
    },
    {
      "scope": [
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "name": "Preprocessor",
      "settings": {
        "foreground": "#d38d97"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "name": "Tag",
      "settings": {
        "foreground": "#ad5c7c"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "name": "Tag Attribute",
      "settings": {
        "foreground": "#5a93aa"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "name": "Brackets",
      "settings": {
        "foreground": "#cbd9d8"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "name": "Deprecated",
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#587b7b"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "name": "Invalid",
      "settings": {
        "foreground": "#e85c51"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "name": "Markdown Heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#73a3b7"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "name": "Markdown Bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#ad5c7c"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "name": "Markdown Italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#ad5c7c"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "name": "Markdown Code",
      "settings": {
        "foreground": "#7aa4a1"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "name": "Markdown Link",
      "settings": {
        "foreground": "#a1cdd8"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "name": "Markdown Quote",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6d7f8b"
      }
    }
  ],
  "name": "terafox",
