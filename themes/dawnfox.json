  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "name": "Comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9893a5"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "name": "String",
      "settings": {
        "foreground": "#618774"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "name": "Regexp",
      "settings": {
        "foreground": "#dd9024"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.numeric"
      ],
      "name": "Number",
      "settings": {
        "foreground": "#d7827e"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character.escape"
      ],
      "name": "Constant",
      "settings": {
        "foreground": "#ca6e69"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "name": "Variable",
      "settings": {
        "foreground": "#575279"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "name": "Variable Property",
      "settings": {
        "foreground": "#286983"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "name": "Keyword",
      "settings": {
        "foreground": "#907aa9"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "name": "Operator",
      "settings": {
        "foreground": "#625c87"
      }
    },
    {
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "name": "Conditional",
      "settings": {
        "foreground": "#816b9a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "name": "Function",
      "settings": {
        "foreground": "#295e73"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "name": "Type",
      "settings": {
        "foreground": "#ea9d34"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "name": "Class",
      "settings": {
        "foreground": "#ea9d34"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "name": "Builtin Type",
      "settings": {
        "foreground": "#50848c"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "name": "Builtin Variable",
      "settings": {
        "foreground": "#b4637a"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "name": "Builtin Constant",
      "settings": {
        "foreground": "#ca6e69"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "name": "Identifier",
      "settings": {
        "foreground": "#56949f"
      }
    },
    {
      "scope": [
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "name": "Preprocessor",
      "settings": {
        "foreground": "#c9709e"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "name": "Tag",
      "settings": {
        "foreground": "#907aa9"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "name": "Tag Attribute",
      "settings": {
        "foreground": "#286983"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "name": "Brackets",
      "settings": {
        "foreground": "#625c87"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "name": "Deprecated",
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#a8a3b3"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "name": "Invalid",
      "settings": {
        "foreground": "#b4637a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "name": "Markdown Heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#295e73"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "name": "Markdown Bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#907aa9"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "name": "Markdown Italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#907aa9"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "name": "Markdown Code",
      "settings": {
        "foreground": "#618774"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "name": "Markdown Link",
      "settings": {
        "foreground": "#56949f"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "name": "Markdown Quote",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9893a5"
      }
    }
  ],
  "name": "dawnfox",
