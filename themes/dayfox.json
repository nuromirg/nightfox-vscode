  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "name": "Comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#837a72"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "name": "String",
      "settings": {
        "foreground": "#396847"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "name": "Regexp",
      "settings": {
        "foreground": "#924702"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.numeric"
      ],
      "name": "Number",
      "settings": {
        "foreground": "#955f61"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character.escape"
      ],
      "name": "Constant",
      "settings": {
        "foreground": "#7f5152"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "name": "Variable",
      "settings": {
        "foreground": "#352c24"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "name": "Variable Property",
      "settings": {
        "foreground": "#2848a9"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "name": "Keyword",
      "settings": {
        "foreground": "#6e33ce"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "name": "Operator",
      "settings": {
        "foreground": "#643f61"
      }
    },
    {
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "name": "Conditional",
      "settings": {
        "foreground": "#5e2baf"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "name": "Function",
      "settings": {
        "foreground": "#223d90"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "name": "Type",
      "settings": {
        "foreground": "#ac5402"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "name": "Class",
      "settings": {
        "foreground": "#ac5402"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "name": "Builtin Type",
      "settings": {
        "foreground": "#22676d"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "name": "Builtin Variable",
      "settings": {
        "foreground": "#a5222f"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "name": "Builtin Constant",
      "settings": {
        "foreground": "#7f5152"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "name": "Identifier",
      "settings": {
        "foreground": "#287980"
      }
    },
    {
      "scope": [
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "name": "Preprocessor",
      "settings": {
        "foreground": "#8b369a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "name": "Tag",
      "settings": {
        "foreground": "#6e33ce"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "name": "Tag Attribute",
      "settings": {
        "foreground": "#2848a9"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "name": "Brackets",
      "settings": {
        "foreground": "#643f61"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "name": "Deprecated",
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#824d5b"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "name": "Invalid",
      "settings": {
        "foreground": "#a5222f"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "name": "Markdown Heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#223d90"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "name": "Markdown Bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#6e33ce"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "name": "Markdown Italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6e33ce"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "name": "Markdown Code",
      "settings": {
        "foreground": "#396847"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "name": "Markdown Link",
      "settings": {
        "foreground": "#287980"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "name": "Markdown Quote",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#837a72"
      }
    }
  ],
  "name": "dayfox",
