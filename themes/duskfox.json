  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "name": "Comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#817c9c"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "name": "String",
      "settings": {
        "foreground": "#a3be8c"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "name": "Regexp",
      "settings": {
        "foreground": "#f9cb8c"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.numeric"
      ],
      "name": "Number",
      "settings": {
        "foreground": "#ea9a97"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character.escape"
      ],
      "name": "Constant",
      "settings": {
        "foreground": "#f0a4a2"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "name": "Variable",
      "settings": {
        "foreground": "#e0def4"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "name": "Variable Property",
      "settings": {
        "foreground": "#569fba"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "name": "Keyword",
      "settings": {
        "foreground": "#c4a7e7"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "name": "Operator",
      "settings": {
        "foreground": "#cdcbe0"
      }
    },
    {
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "name": "Conditional",
      "settings": {
        "foreground": "#ccb1ed"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "name": "Function",
      "settings": {
        "foreground": "#65b1cd"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "name": "Type",
      "settings": {
        "foreground": "#f6c177"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "name": "Class",
      "settings": {
        "foreground": "#f6c177"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "name": "Builtin Type",
      "settings": {
        "foreground": "#a6dae3"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "name": "Builtin Variable",
      "settings": {
        "foreground": "#eb6f92"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "name": "Builtin Constant",
      "settings": {
        "foreground": "#f0a4a2"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "name": "Identifier",
      "settings": {
        "foreground": "#9ccfd8"
      }
    },
    {
      "scope": [
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "name": "Preprocessor",
      "settings": {
        "foreground": "#f0a6cc"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "name": "Tag",
      "settings": {
        "foreground": "#c4a7e7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "name": "Tag Attribute",
      "settings": {
        "foreground": "#569fba"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "name": "Brackets",
      "settings": {
        "foreground": "#cdcbe0"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "name": "Deprecated",
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#6e6a86"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "name": "Invalid",
      "settings": {
        "foreground": "#eb6f92"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "name": "Markdown Heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#65b1cd"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "name": "Markdown Bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#c4a7e7"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "name": "Markdown Italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#c4a7e7"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "name": "Markdown Code",
      "settings": {
        "foreground": "#a3be8c"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "name": "Markdown Link",
      "settings": {
        "foreground": "#9ccfd8"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "name": "Markdown Quote",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#817c9c"
      }
    }
  ],
